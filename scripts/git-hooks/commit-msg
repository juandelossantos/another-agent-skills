#!/usr/bin/env bash
# commit-msg — Another Agent Skills Three-Gate Approval Check (v6)
# Verifies THREE conditions before allowing a commit:
# 1. COMMIT_APPROVED — timestamp <5 min, message matches
# 2. COMMIT_MANIFEST — exists, has content
# 3. TEST_LOG — exists, status=PASS, recent
#
# Logs every approval attempt to .git/APPROVAL_LOG for audit.

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
APPROVAL_FILE="${REPO_ROOT}/.git/COMMIT_APPROVED"
MANIFEST_FILE="${REPO_ROOT}/.git/COMMIT_MANIFEST"
TEST_LOG="${REPO_ROOT}/.git/TEST_LOG"
APPROVAL_LOG="${REPO_ROOT}/.git/APPROVAL_LOG"
COMMIT_MSG_FILE="${1:-${REPO_ROOT}/.git/COMMIT_EDITMSG}"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

CURRENT_MSG=$(head -1 "$COMMIT_MSG_FILE" | tr -d '\n')
NOW_EPOCH=$(date +%s)

fail() {
  local reason="$1"
  echo ""
  echo "╔════════════════════════════════════════════════════════════╗"
  echo "║  ❌ COMMIT BLOCKED                                       ║"
  echo "╠════════════════════════════════════════════════════════════╣"
  echo "║  $reason"
  echo "╠════════════════════════════════════════════════════════════╣"
  echo "║  Missing gates are listed above. Complete each before     ║"
  echo "║  attempting to commit again.                             ║"
  echo "╚════════════════════════════════════════════════════════════╝"
  echo "  Timestamp: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  echo "  Message: ${CURRENT_MSG}"
  echo ""
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] BLOCKED: ${CURRENT_MSG} — ${reason}" >> "$APPROVAL_LOG"
  exit 1
}

GATES_PASSED=0
GATES_TOTAL=3
MISSING=""

# ─────────────────────────────────────────
# Gate 1: TEST_LOG exists, status=PASS, recent
# ─────────────────────────────────────────
if [[ -f "$TEST_LOG" ]]; then
  STATUS=$(grep "^status=" "$TEST_LOG" | cut -d= -f2-)
  if [[ "$STATUS" == "PASS" ]]; then
    TS=$(grep "^timestamp=" "$TEST_LOG" | cut -d= -f2-)
    TS_EPOCH=$(date -d "$TS" +%s 2>/dev/null || echo 0)
    AGE=$((NOW_EPOCH - TS_EPOCH))
    if [ $AGE -le 3600 ]; then
      GATES_PASSED=$((GATES_PASSED + 1))
      echo -e "  ${GREEN}✓${NC} Gate 1/3: Tests passed (${AGE}s ago)"
    else
      MISSING="${MISSING}  - Gate 1/3: TEST_LOG expired (>1 hour old)\n"
    fi
  else
    MISSING="${MISSING}  - Gate 1/3: TEST_LOG shows FAIL status\n"
  fi
else
  MISSING="${MISSING}  - Gate 1/3: TEST_LOG missing (run tests first: bash scripts/log-test-results.sh)\n"
fi

# ─────────────────────────────────────────
# Gate 2: COMMIT_MANIFEST exists, has content
# ─────────────────────────────────────────
if [[ -f "$MANIFEST_FILE" ]]; then
  SIZE=$(wc -c < "$MANIFEST_FILE")
  if [ "$SIZE" -gt 20 ]; then
    GATES_PASSED=$((GATES_PASSED + 1))
    echo -e "  ${GREEN}✓${NC} Gate 2/3: Commit manifest present"
  else
    MISSING="${MISSING}  - Gate 2/3: COMMIT_MANIFEST is empty\n"
  fi
else
  MISSING="${MISSING}  - Gate 2/3: COMMIT_MANIFEST missing\n"
fi

# ─────────────────────────────────────────
# Gate 3: COMMIT_APPROVED exists, <5 min, message matches
# ─────────────────────────────────────────
if [[ -f "$APPROVAL_FILE" ]]; then
  TIMESTAMP=$(grep "^timestamp=" "$APPROVAL_FILE" | cut -d= -f2-)
  STORED_MSG=$(grep "^message=" "$APPROVAL_FILE" | cut -d= -f2-)

  if [ -z "$TIMESTAMP" ]; then
    MISSING="${MISSING}  - Gate 3/3: COMMIT_APPROVED invalid (missing timestamp)\n"
  else
    TS_EPOCH=$(date -d "$TIMESTAMP" +%s 2>/dev/null || echo 0)
    AGE=$((NOW_EPOCH - TS_EPOCH))

    if [ $AGE -gt 300 ] || [ $AGE -lt 0 ]; then
      MISSING="${MISSING}  - Gate 3/3: Approval expired (${AGE}s ago, max 300s)\n"
    elif [ "$STORED_MSG" != "$CURRENT_MSG" ]; then
      MISSING="${MISSING}  - Gate 3/3: Commit message changed after approval\n"
    else
      GATES_PASSED=$((GATES_PASSED + 1))
      echo -e "  ${GREEN}✓${NC} Gate 3/3: Approval fresh (${AGE}s, <5 min)"
    fi
  fi
else
  MISSING="${MISSING}  - Gate 3/3: COMMIT_APPROVED missing (run bash scripts/commit-approval.sh)\n"
fi

# ─────────────────────────────────────────
# Result
# ─────────────────────────────────────────
if [ $GATES_PASSED -eq $GATES_TOTAL ]; then
  echo ""
  echo -e "${GREEN}✓ All 3 gates passed. Commit allowed.${NC}"
  # Log success
  echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] APPROVED: ${CURRENT_MSG}" >> "$APPROVAL_LOG"
  # Cleanup
  rm -f "$APPROVAL_FILE" "$MANIFEST_FILE"
  exit 0
else
  echo ""
  echo -e "${RED}✗ Gates passed: ${GATES_PASSED}/${GATES_TOTAL}${NC}"
  echo ""
  echo -e "${MISSING}" | head -10
  fail "Commit blocked: not all gates passed."
fi
