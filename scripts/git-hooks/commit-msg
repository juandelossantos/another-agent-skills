#!/usr/bin/env bash
# commit-msg — Another Agent Skills TDD Gate Only (v6)
# Single gate: TDD enforcement. No override mechanism — every change needs a test.
#
# Flow:
# 1. Agent stages files and presents DECISION POINT in chat
# 2. User approves, writes DECISION_APPROVED token
# 3. User runs: git commit -m "message"
# 4. commit-msg hook runs TDD gate — no override possible

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
APPROVAL_LOG="${REPO_ROOT}/.git/APPROVAL_LOG"
TDD_GATE="${REPO_ROOT}/scripts/tdd-gate.sh"
COMMIT_MSG_FILE="${1:-${REPO_ROOT}/.git/COMMIT_EDITMSG}"

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
NC=$'\033[0m'

CURRENT_MSG=$(head -1 "$COMMIT_MSG_FILE" | tr -d '\n')

# ─────────────────────────────────────────
# Gate 1: TDD gate — every code change needs a test. No override.
# ─────────────────────────────────────────
if [[ -f "$TDD_GATE" ]]; then
  TDD_OUTPUT=$(bash "$TDD_GATE" 2>&1)
  TDD_EXIT=$?
  if [ $TDD_EXIT -eq 0 ]; then
    echo -e "  ${GREEN}✓${NC} TDD gate passed"
  else
    echo ""
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  ❌ COMMIT BLOCKED — TDD gate failed                     ║"
    echo "╠════════════════════════════════════════════════════════════╣"
    echo "║  Every code change requires a matching test.              ║"
    echo "║  No override mechanism exists — all changes need tests.   ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    echo ""
    echo "$TDD_OUTPUT"
    echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] TDD_BLOCKED: ${CURRENT_MSG}" >> "$APPROVAL_LOG"
    exit 1
  fi
else
  echo "  ${YELLOW}−${NC} TDD gate script not found — skipped"
fi

echo ""
echo -e "${GREEN}✓ Commit allowed.${NC}"
echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] ALLOWED: ${CURRENT_MSG}" >> "$APPROVAL_LOG"
exit 0
