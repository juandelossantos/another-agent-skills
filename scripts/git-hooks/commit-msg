#!/usr/bin/env bash
# commit-msg — Another Agent Skills Hash Verification (v4)
# SINGLE SOURCE OF TRUTH for commit approval validation.
# pre-commit hook (v7) no longer validates tokens — this hook does.
#
# Verifies commit message hash against .git/COMMIT_APPROVED token.
# Algorithm: sha256(message + "\t" + timestamp) must match stored hash.
# Token format: hash\ttimestamp (tab-separated)
#
# After successful validation, DELETES the token so it cannot be reused.
# No token after commit = next commit must go through approval flow.

set -euo pipefail

APPROVAL_FILE=".git/COMMIT_APPROVED"
COMMIT_MSG_FILE="${1:-.git/COMMIT_EDITMSG}"

if [ ! -f "$APPROVAL_FILE" ]; then
    echo ""
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  BLOCKED: No commit approval token found.               ║"
    echo "║                                                          ║"
    echo "║  The agent must present a Commit Manifest and get        ║"
    echo "║  your explicit approval before committing.               ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

TOKEN_CONTENT=$(cat "$APPROVAL_FILE" 2>/dev/null || echo "")
TOKEN_HASH=$(echo "$TOKEN_CONTENT" | cut -d$'\t' -f1)
TOKEN_TS=$(echo "$TOKEN_CONTENT" | cut -d$'\t' -f2)

COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE" | tr -d '\n')

ACTUAL_HASH=$(printf '%s\t%s' "$COMMIT_MSG" "$TOKEN_TS" | sha256sum | cut -d' ' -f1)

if [ "$TOKEN_HASH" != "$ACTUAL_HASH" ]; then
    echo ""
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  BLOCKED: Token hash mismatch.                          ║"
    echo "║                                                          ║"
    echo "║  The COMMIT_APPROVED token does not match the           ║"
    echo "║  commit message. Possible causes:                       ║"
    echo "║  - Commit message was modified after token creation     ║"
    echo "║  - Token was created for a different commit             ║"
    echo "║                                                          ║"
    echo "║  To proceed:                                            ║"
    echo "║  1. Restore original commit message, OR                  ║"
    echo "║  2. Run Commit Manifest Protocol again to get new token  ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

rm -f "$APPROVAL_FILE"
exit 0
