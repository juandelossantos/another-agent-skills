#!/usr/bin/env bash
# pre-commit — Another Agent Skills Pre-Flight + Mutation Approval Gate (v7)
# Installed by init-agents.sh.
# 1) Runs pre-flight check (working tree, branch, upstream, remote)
# 2) Structural integrity gate on staged HTML files
# 3) Escape hatch: OVERRIDE: reason → logged, 3 escapes = ESCALATION
# 4) Build verification: bash -n on staged shell scripts
# 5) Anti-slop: detect generic AI-generated patterns
# 6) Debug 3-strikes: track fix/debug commits, escalate at 3
# 7) SPEC enforcement: warn when new scripts lack spec
#
# Token validation moved to commit-msg hook (v7).
# pre-commit runs BEFORE commit message is written, so it cannot
# validate a token that depends on the message hash.
# commit-msg runs AFTER message is written and handles validation + cleanup.
#
# v7: Remove token validation from pre-commit (design bug fix)

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

COMMIT_APPROVED="${REPO_ROOT}/.git/COMMIT_APPROVED"
OVERRIDE_LOG="${REPO_ROOT}/.git/OVERRIDE_LOG"
ESCALATION_THRESHOLD=3

count_overrides() {
  if [ ! -f "$OVERRIDE_LOG" ]; then echo 0; return; fi
  grep -c "|agent|pre-commit|" "$OVERRIDE_LOG" 2>/dev/null || echo 0
}

echo ""
echo "╔════════════════════════════════════════════╗"
echo "║  PRE-FLIGHT CHECK                          ║"
echo "╚════════════════════════════════════════════╝"

# 1. Branch check
BRANCH=$(git branch --show-current)
if [ -z "$BRANCH" ]; then
  echo "  ${RED}✗${NC} Detached HEAD. Checkout a branch before committing."
  exit 1
fi
echo "  ${GREEN}✓${NC} Branch: $BRANCH"

# 2. Staged changes
if [ -n "$(git status --porcelain)" ]; then
  echo "  ${GREEN}✓${NC} Staged changes ready"
else
  echo "  ${YELLOW}⚠${NC} No staged changes. Did you forget 'git add'?"
fi

# 3. Unpulled remote changes (only when behind, not ahead)
LOCAL=$(git rev-parse HEAD)
REMOTE=$(git rev-parse origin/main 2>/dev/null || echo "$LOCAL")
if [ "$LOCAL" != "$REMOTE" ]; then
  if ! git merge-base --is-ancestor "$REMOTE" "$LOCAL" 2>/dev/null; then
    echo "  ${RED}✗${NC} Unpulled remote changes detected. Run 'git pull --rebase' first."
    exit 1
  fi
fi
echo "  ${GREEN}✓${NC} Remote up to date"

# 4. Structural integrity gate (staged HTML files)
EDIT_GUARD="${REPO_ROOT}/scripts/edit-guard.sh"
if [ -f "$EDIT_GUARD" ]; then
  STAGED_HTML=$(git diff --cached --name-only --diff-filter=ACM | grep -i '\.html$' || true)
  if [ -n "$STAGED_HTML" ]; then
    echo "  ${GREEN}✓${NC} Structural integrity check on HTML files..."
    INTEGRITY_FAIL=0
    for f in $STAGED_HTML; do
      if [ ! -f "$f" ]; then continue; fi
      FILENAME=$(basename "$f")
      case "$FILENAME" in
        index.html)
          if ! bash "$EDIT_GUARD" check "$f" \
            "lifecycle-flow" "hero__actions" \
            "</main>" "</html>" "DOCTYPE"; then
            echo "    ${RED}✗${NC} $f — structural markers missing"
            INTEGRITY_FAIL=1
          else
            echo "    ${GREEN}✓${NC} $f — all markers present"
          fi
          ;;
        *)
          if ! bash "$EDIT_GUARD" check "$f" "DOCTYPE" "</html>"; then
            echo "    ${RED}✗${NC} $f — basic structure missing"
            INTEGRITY_FAIL=1
          else
            echo "    ${GREEN}✓${NC} $f — basic structure valid"
          fi
          ;;
      esac
    done
    if [ "$INTEGRITY_FAIL" -eq 1 ]; then
      echo ""
      echo "  ${RED}╔═══════════════════════════════════════════════════════════╗${NC}"
      echo "  ${RED}║  STRUCTURAL INTEGRITY BLOCKED                           ║${NC}"
      echo "  ${RED}║                                                         ║${NC}"
      echo "  ${RED}║  Staged HTML files are missing critical structural       ║${NC}"
      echo "  ${RED}║  markers. File sections may have been deleted.          ║${NC}"
      echo "  ${RED}║                                                         ║${NC}"
      echo "  ${RED}║  Read the file, identify missing sections, and restore.  ║${NC}"
      echo "  ${RED}║  Use: git diff --cached -- <file> for staged version.   ║${NC}"
      echo "  ${RED}╚═══════════════════════════════════════════════════════════╝${NC}"
      echo ""
      exit 1
    fi
  fi
fi

# 5. Mutation approval — handled by commit-msg hook (runs after message is written)
# Token validation moved to commit-msg hook v7 because pre-commit runs BEFORE
# COMMIT_EDITMSG is written, making hash validation impossible here.
# If no token exists when commit-msg runs, it will BLOCK and require approval.

OVERRIDE_COUNT=$(count_overrides)
if [ "$OVERRIDE_COUNT" -ge "$ESCALATION_THRESHOLD" ]; then
  echo ""
  echo "╔════════════════════════════════════════════════════════════╗"
  echo "║  ESCALATION REQUIRED                                      ║"
  echo "║                                                          ║"
  echo "║  This branch has ${OVERRIDE_COUNT} override(s) logged.               ║"
  echo "║                                                          ║"
  echo "║  This is a process violation pattern.                    ║"
  echo "║                                                          ║"
  echo "║  STOP. Do not continue.                                  ║"
  echo "║  Get explicit user approval for a complete session review.║"
  echo "╚════════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

# ============================================================
# PHASE 3 GATES
# ============================================================

# 6. Skill Gate — verify skills were consulted before implementation
echo ""
echo "╔════════════════════════════════════════════╗"
echo "║  SKILL GATE                                ║"
echo "╚════════════════════════════════════════════╝"

SKILL_GATE="${REPO_ROOT}/scripts/skill-gate.sh"
if [ -f "$SKILL_GATE" ]; then
  if ! bash "$SKILL_GATE" check 2>&1; then
    echo ""
    echo "  ${RED}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo "  ${RED}║  SKILL GATE BLOCKED                                     ║${NC}"
    echo "  ${RED}║                                                         ║${NC}"
    echo "  ${RED}║  Rule 1: 'Always check skills first.'                  ║${NC}"
    echo "  ${RED}║                                                         ║${NC}"
    echo "  ${RED}║  No skills were consulted before implementation.        ║${NC}"
    echo "  ${RED}║                                                         ║${NC}"
    echo "  ${RED}║  Required:                                              ║${NC}"
    echo "  ${RED}║  1. Load using-agent-skills                             ║${NC}"
    echo "  ${RED}║  2. Identify applicable skill                           ║${NC}"
    echo "  ${RED}║  3. Load and follow the skill                           ║${NC}"
    echo "  ${RED}║                                                         ║${NC}"
    echo "  ${RED}║  To bypass: echo 'override: reason' > .git/SKILLS_     ║${NC}"
    echo "  ${RED}║             CONSULTED                                   ║${NC}"
    echo "  ${RED}╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    exit 1
  fi
else
  echo "  ${YELLOW}−${NC} skill-gate.sh not found — skipped"
fi

# 6. Build Verification Gate — syntax check shell scripts
echo ""
echo "╔════════════════════════════════════════════╗"
echo "║  BUILD VERIFICATION                       ║"
echo "╚════════════════════════════════════════════╝"

BUILD_FAIL=0
STAGED_SHELL=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(sh|bash)$' || true)
if [ -n "$STAGED_SHELL" ]; then
  echo "  Checking shell script syntax..."
  for f in $STAGED_SHELL; do
    if [ ! -f "$f" ]; then continue; fi
    if bash -n "$f" 2>&1; then
      echo "    ${GREEN}✓${NC} $f — syntax OK"
    else
      echo "    ${RED}✗${NC} $f — syntax error"
      BUILD_FAIL=1
    fi
  done
  if [ "$BUILD_FAIL" -eq 1 ]; then
    echo ""
    echo "  ${RED}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo "  ${RED}║  BUILD VERIFICATION FAILED                              ║${NC}"
    echo "  ${RED}║                                                         ║${NC}"
    echo "  ${RED}║  Shell script syntax errors detected. Fix before       ║${NC}"
    echo "  ${RED}║  committing. Run: bash -n <file> to diagnose.          ║${NC}"
    echo "  ${RED}╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    exit 1
  fi
else
  echo "  ${YELLOW}−${NC} No shell scripts staged — skipped"
fi

# 7. Anti-Slop Gate — detect generic AI-generated patterns
echo ""
echo "╔════════════════════════════════════════════╗"
echo "║  ANTI-SLOP DETECTION                       ║"
echo "╚════════════════════════════════════════════╝"

SLOP_PATTERNS=(
  "I'd be happy to"
  "I'd love to"
  "Sure thing"
  "Here's the code"
  "This is a placeholder"
  "Lorem ipsum"
  "temp.placeholder"
  "TODO: fix this later"
  "The following code"
  "As you can see"
)

SLOP_FAIL=0
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM | xargs -I {} echo "{}" 2>/dev/null || true)
if [ -n "$STAGED_ALL" ]; then
  echo "  Scanning for AI slop patterns..."
  for f in $STAGED_ALL; do
    if [ ! -f "$f" ]; then continue; fi
    case "$f" in
      *.png|*.jpg|*.jpeg|*.gif|*.svg|*.ico) continue ;;
      *.lock|*.sum) continue ;;
      scripts/git-hooks/*|.git/hooks/*) continue ;;
    esac
    for pattern in "${SLOP_PATTERNS[@]}"; do
      if grep -qF "$pattern" "$f" 2>/dev/null; then
        echo "    ${RED}✗${NC} $f — contains slop: '$pattern'"
        SLOP_FAIL=1
      fi
    done
  done
  if [ "$SLOP_FAIL" -eq 1 ]; then
    echo ""
    echo "  ${RED}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo "  ${RED}║  ANTI-SLOP BLOCKED                                     ║${NC}"
    echo "  ${RED}║                                                         ║${NC}"
    echo "  ${RED}║  Generic AI-generated content detected. Remove or       ║${NC}"
    echo "  ${RED}║  replace with project-specific content.                 ║${NC}"
    echo "  ${RED}║                                                         ║${NC}"
    echo "  ${RED}║  Patterns detected: filler phrases, placeholder text, ║${NC}"
    echo "  ${RED}║  generic explanations that add no value.               ║${NC}"
    echo "  ${RED}╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    exit 1
  fi
  echo "  ${GREEN}✓${NC} No slop patterns detected"
else
  echo "  ${YELLOW}−${NC} No files staged — skipped"
fi

# 8. Debug 3-Strikes Gate — track fix/debug commits
echo ""
echo "╔════════════════════════════════════════════╗"
echo "║  DEBUG STRIKES TRACKING                    ║"
echo "╚════════════════════════════════════════════╝"

DEBUG_LOG="${REPO_ROOT}/.git/DEBUG_STRIKES"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE" 2>/dev/null | tr '[:upper:]' '[:lower:]' || echo "")

  DEBUG_STRIKE=0
  if echo "$COMMIT_MSG" | grep -qE '^(fix|hotfix|bug|debug|patch)[:\s]'; then
    DEBUG_STRIKE=1
    DEBUG_COUNT=$(grep -c "DEBUG_STRIKE" "$DEBUG_LOG" 2>/dev/null || echo "0")
    DEBUG_COUNT=$((${DEBUG_COUNT:-0} + 1))
    echo "$COMMIT_MSG" | cut -c1-60 > "$DEBUG_LOG"
    echo "DEBUG_STRIKE:$DEBUG_COUNT:$(date +%s)" >> "$DEBUG_LOG"
    echo "  ${YELLOW}⚠${NC} Debug/fix commit detected (strike $DEBUG_COUNT/3)"
  else
    DEBUG_COUNT=$(grep -c "DEBUG_STRIKE" "$DEBUG_LOG" 2>/dev/null || echo "0")
    if [ "${DEBUG_COUNT:-0}" -gt 0 ]; then
    echo "  ${YELLOW}−${NC} Previous debug strikes: $DEBUG_COUNT"
  else
    echo "  ${GREEN}✓${NC} No debug strikes"
  fi
fi

if [ "$DEBUG_COUNT" -ge 3 ]; then
  echo ""
  echo "  ${RED}╔═══════════════════════════════════════════════════════════╗${NC}"
  echo "  ${RED}║  DEBUG 3-STRIKES ESCALATION                             ║${NC}"
  echo "  ${RED}║                                                         ║${NC}"
  echo "  ${RED}║  This branch has $DEBUG_COUNT debug/fix commits.                  ║${NC}"
  echo "  ${RED}║                                                         ║${NC}"
  echo "  ${RED}║  Pattern suggests:                                      ║${NC}"
  echo "  ${RED}║  - Symptom not root cause being fixed repeatedly         ║${NC}"
  echo "  ${RED}║  - Missing test coverage for regression                  ║${NC}"
  echo "  ${RED}║  - Technical debt being patched, not resolved           ║${NC}"
  echo "  ${RED}║                                                         ║${NC}"
  echo "  ${RED}║  Required: Debug session with test coverage analysis.    ║${NC}"
  echo "  ${RED}║  Use: skill debugging-and-error-recovery                 ║${NC}"
  echo "  ${RED}╚═══════════════════════════════════════════════════════════╝${NC}"
  echo ""
  exit 1
fi

# 9. SPEC Gate — check for spec when committing new functionality
echo ""
echo "╔════════════════════════════════════════════╗"
echo "║  SPEC ENFORCEMENT                           ║"
echo "╚════════════════════════════════════════════╝"

STAGED_NEW_SCRIPT=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^scripts/[^g]' || true)
if [ -n "$STAGED_NEW_SCRIPT" ]; then
  if ! git diff --cached --name-only | grep -qE '(SPEC\.md|DESIGN\.md|design/)'; then
    echo "  ${YELLOW}⚠${NC} New script(s) staged without spec update:"
    echo "    $STAGED_NEW_SCRIPT" | tr ' ' '\n' | sed 's/^/    /'
    echo ""
    echo "  ${YELLOW}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo "  ${YELLOW}║  SPEC RECOMMENDED                                       ║${NC}"
    echo "  ${YELLOW}║                                                         ║${NC}"
    echo "  ${YELLOW}║  New scripts should be accompanied by spec or design    ║${NC}"
    echo "  ${YELLOW}║  doc. This is not blocked but is tracked.               ║${NC}"
    echo "  ${YELLOW}║                                                         ║${NC}"
    echo "  ${YELLOW}║  To skip: Add OVERRIDE: reason before your commit msg   ║${NC}"
    echo "  ${YELLOW}╚═══════════════════════════════════════════════════════════╝${NC}"
  else
    echo "  ${GREEN}✓${NC} Spec/design doc updated alongside scripts"
  fi
else
  echo "  ${YELLOW}−${NC} No new scripts — skipped"
fi

# 10. Skill Lint Gate — validate skill structure on SKILL.md changes
echo ""
echo "╔════════════════════════════════════════════╗"
echo "║  SKILL LINT                                ║"
echo "╚════════════════════════════════════════════╝"

SKILL_LINT="${REPO_ROOT}/scripts/skill-lint.sh"
STAGED_SKILLS=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'skills/.*/SKILL\.md$' || true)
if [ -n "$STAGED_SKILLS" ] && [ -f "$SKILL_LINT" ]; then
  echo "  Checking skill structure compliance..."
  if bash "$SKILL_LINT" "$REPO_ROOT/skills"; then
    echo "  ${GREEN}✓${NC} All skills compliant"
  else
    echo ""
    echo "  ${RED}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo "  ${RED}║  SKILL LINT FAILED                                       ║${NC}"
    echo "  ${RED}║                                                         ║${NC}"
    echo "  ${RED}║  One or more skills violate Rule 6 (skills as indexes).  ║${NC}"
    echo "  ${RED}║  Move detailed content to guides/ and keep SKILL.md     ║${NC}"
    echo "  ${RED}║  as a ~250-line index.                                   ║${NC}"
    echo "  ${RED}╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    exit 1
  fi
else
  echo "  ${YELLOW}−${NC} No SKILL.md changes — skipped"
fi

echo ""
echo "  ${GREEN}✓${NC} All Phase 3 gates passed"
echo ""
exit 0
