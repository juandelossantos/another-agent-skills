# Another Agent Skills — Environment Configuration
#
# This project is a meta-framework (shell + markdown). No application runtime
# requires environment variables. These are for local development tooling.

# GitHub token for PR/issue operations (optional, for gh CLI)
# GITHUB_TOKEN=

# OpenCode API key (optional, for agent features)
# OPENCODE_API_KEY=

# Agent skills directory (default: ~/.config/opencode/skills)
# AGENT_SKILLS_DIR=
